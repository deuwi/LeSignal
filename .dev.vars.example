# Copie vers .dev.vars (gitignoré) et remplis. JAMAIS commité.
# Phase 1 n'a besoin d'AUCUN secret. Ces clés servent aux phases suivantes.

# Phase 2 — LLM curation (Anthropic Haiku)
ANTHROPIC_API_KEY=

# Phase 3 — Notion (token d'intégration interne Notion)
NOTION_TOKEN=
NOTION_DB_ID=

# Protège les actions d'écriture (créer dans Notion) sur l'app publique.
# Mets une longue chaîne aléatoire. Saisie 1× dans le dashboard (localStorage).
ADMIN_TOKEN=

# Sources `search` (Cursor, Codex, Free-Work, APEC) via Brave Search API
# Clé gratuite : brave.com/search/api
BRAVE_API_KEY=

# Optionnel — France Travail (source chiffres marché FR)
FT_CLIENT_ID=
FT_CLIENT_SECRET=
